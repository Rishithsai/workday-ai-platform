{
  "manifest_version": 3,

  "name": "AI Workday Autofill",

  "version": "1.0",

  "description": "AI-powered Workday autofill extension",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],

      "js": [
        "content.js"
      ],

      "run_at": "document_idle"
    }
  ]
}